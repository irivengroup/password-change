---
# Encrypt this whole file:
#   ansible-vault encrypt inventories/production/group_vars/all/vault.yml

# REQUIRED
# Replace this value with a strong custom HMAC salt secret.
# Minimum: 32 characters.
# Complexity: at least one uppercase letter, one lowercase letter, one digit,
# and one special character.
# If this value is empty or does not satisfy the policy defined in defaults/main.yml,
# the role automatically falls back to iriven_chgpasswd_default_hmac_salt_secret.
# Example:
# iriven_chgpasswd_hmac_salt_secret: "MyStrongCustomSecret#2026-ChangeThis"
iriven_chgpasswd_hmac_salt_secret: ""

# unix_local_accounts is a list of dictionaries, not a mapping keyed by username.
# manage_password defaults to true.
# password is auto-detected:
#   - starts with $6$  => SHA512 crypt hash, passed through
#   - starts with $5$  => SHA256 crypt hash, passed through
#   - otherwise       => Vault-protected plaintext, hashed on the controller
unix_local_accounts:
  - username: root
    password: "replace-with-vault-secret-root-password"

  - username: ansible
    password: "replace-with-vault-secret-ansible-password"
    state: unlocked

  - username: svc_backup
    password: "$6$rounds=656000$replaceSaltHere$replaceSha512CryptHashHere"
    state: locked
    expire: false
